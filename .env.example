# TinyCopyServer Configuration
# Copy this file to .env and update values for production

# Admin Credentials
TCS_ADMIN_USER=admin
TCS_ADMIN_PASS=tcs2024secure

# JWT Secret (change in production!)
TCS_JWT_SECRET=your-super-secret-key-change-in-production-12345

# Database
# Uses SQLite by default, stored in ./data/tcs.db
# TCS_DATA_DIR=./data

# Max upload size (bytes) - default 500 MB
# TCS_MAX_UPLOAD_SIZE=524288000

# Anonymous upload limit per session (bytes) - default 50 MB
# TCS_ANON_UPLOAD_LIMIT=52428800

# Compression level (1-22, default 10 for balance)
# TCS_COMPRESSION_LEVEL=10

# JWT expiration in hours
# TCS_JWT_EXPIRATION_HOURS=24

# Server configuration
# Uncomment to change defaults
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
